# ─── SignFlow Enterprise — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=SignFlow Enterprise
VITE_APP_URL=http://localhost:3000

# ── Backend API (when you add a real backend) ─────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api/v1

# ── Authentication ────────────────────────────────────────────────────────────
# Auth0 (or replace with your JWT secret on the server)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id

# ── File Storage (AWS S3) ─────────────────────────────────────────────────────
# These should ONLY be set server-side (NestJS/Express backend), never in frontend
# VITE_AWS_REGION=ap-south-1
# VITE_S3_BUCKET=signflow-documents

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# Server-side only
# SENDGRID_API_KEY=SG.xxxxx

# ── Database ──────────────────────────────────────────────────────────────────
# Server-side only
# DATABASE_URL=postgresql://user:pass@localhost:5432/signflow

# ── Redis ─────────────────────────────────────────────────────────────────────
# Server-side only
# REDIS_URL=redis://localhost:6379
